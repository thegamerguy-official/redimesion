generator py {
  provider  = "prisma-client-py"
  interface = "sync"
}

generator js {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  
  skus        SKU[]
  boxTypes    BoxType[]
  orders      OrderHistory[]
}

model SKU {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  skuCode     String   @db.VarChar(100)
  name        String   @db.VarChar(255)
  
  length_cm   Float    @db.Real
  width_cm    Float    @db.Real
  height_cm   Float    @db.Real
  weight_g    Float    @db.Real
  
  orderItems  OrderItem[]

  @@unique([tenantId, skuCode])
  @@index([tenantId])
}

model BoxType {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String   @db.VarChar(255)
  
  length_cm      Float    @db.Real
  width_cm       Float    @db.Real
  height_cm      Float    @db.Real
  
  grammage_kg_m2 Float    @default(0.5) @db.Real
  
  orders         OrderHistory[]

  @@index([tenantId])
}

model OrderHistory {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderReference   String   @db.VarChar(100)
  
  selectedBoxId    String   @db.Uuid
  selectedBox      BoxType  @relation(fields: [selectedBoxId], references: [id], onDelete: Restrict)
  
  redLength_cm     Float    @db.Real
  redWidth_cm      Float    @db.Real
  redHeight_cm     Float    @db.Real
  redVolume_cm3    Float    @db.Real
  
  theoLength_cm    Float    @db.Real
  theoWidth_cm     Float    @db.Real
  theoHeight_cm    Float    @db.Real
  theoVolume_cm3   Float    @db.Real
  
  processedAt      DateTime @default(now()) @db.Timestamptz(3)
  
  items            OrderItem[]

  // Indices estrategicos para optimizacion de agregaciones y lecturas masivas
  @@index([tenantId, processedAt(sort: Desc)])
  @@index([tenantId, orderReference])
  @@index([selectedBoxId])
}

model OrderItem {
  id              String       @id @default(uuid()) @db.Uuid
  orderHistoryId  String       @db.Uuid
  orderHistory    OrderHistory @relation(fields: [orderHistoryId], references: [id], onDelete: Cascade)
  skuId           String       @db.Uuid
  sku             SKU          @relation(fields: [skuId], references: [id], onDelete: Restrict)
  quantity        Int          @db.SmallInt
  
  @@index([orderHistoryId])
  @@index([skuId])
}
